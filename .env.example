# Copy this file to .env and fill in the keys for the providers you want to use.
# .env is gitignored - real keys never get committed.
#
# You only need a key for the provider(s) you're benchmarking. The idiom judge
# (SHARPBENCH_JUDGE_MODEL, default claude-opus-4-8) also needs its provider's key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides:
# SHARPBENCH_JUDGE_MODEL=claude-opus-4-8
# OLLAMA_HOST=http://localhost:11434
